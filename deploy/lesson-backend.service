[Unit]
Description=Lesson Schedule Backend (Gunicorn)
After=network.target

[Service]
User=qutb
Group=qutb
WorkingDirectory=/home/qutb/lesson_schedule_assistant/backend
Environment="DJANGO_SECRET_KEY=CHANGE_ME"
Environment="DEBUG=False"
Environment="ALLOWED_HOSTS=moldir.gonzo.ink"
ExecStart=/home/qutb/lesson_schedule_assistant/backend/.venv/bin/gunicorn config.wsgi:application --bind 127.0.0.1:8000 --workers 2
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
